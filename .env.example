# ── .env.example ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is in .gitignore — NEVER commit real credentials.
#
# Usage:
#   npx dotenv -e .env -- npx playwright test
# ─────────────────────────────────────────────────────────────────────────────

# Target application
BASE_URL=http://hasibcore.hasib.com.sa:8090
LOGIN_PATH=/HPA.NBU/#!/login

# Credentials
APP_USERNAME=portaladmin
APP_PASSWORD=1234560

# Data paths (optional — defaults to data/questions.csv and results/)
INPUT_CSV=data/questions.csv
OUTPUT_DIR=results

# Timing overrides (ms) — increase if the chatbot is slow
CHAT_RESPONSE_TIMEOUT_MS=120000
INTER_QUESTION_DELAY_MS=2000

# Debug helpers
SLOW_MO=0
